# Database
DB_FILE=cms.db

# Server
NODE_ENV=production
PORT=3000

# Security (REQUIRED — no fallback)
SESSION_SECRET=change-me-to-a-256-bit-random-string-min-32-chars

# GitHub OAuth (REQUIRED for write access)
GITHUB_CLIENT_ID=your-oauth-app-id
GITHUB_CLIENT_SECRET=your-oauth-app-secret
GITHUB_WEBHOOK_SECRET=your-webhook-secret
GITHUB_REPO=owner/repo-name

# App context
IS_CLIENT_RELEASE=false
