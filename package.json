{
  "name": "rr7-cms",
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "react-router dev",
    "build": "react-router build",
    "start": "react-router-serve build/server/index.js",
    "build:release": "node -e \"require('node:sqlite').DatabaseSync('cms.db').exec('PRAGMA wal_checkpoint(TRUNCATE)')\" && tsx scripts/build-release.ts",
    "start:release": "IS_CLIENT_RELEASE=true DB_FILE=release.db node server.js",
    "electron:start": "npm run build:release && electron .",
    "electron:build": "npm run build:release && electron-builder build -lw",
    "bun:build": "npm run build:release && bun build ./server.js --compile --outfile release/caedocs",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "build": {
    "appId": "com.cae.docs",
    "productName": "CAE Docs Viewer",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "build/**/*",
      "server.js",
      "electron/main.cjs",
      "package.json"
    ],
    "extraResources": [
      "release.db"
    ],
    "linux": {
      "target": "AppImage",
      "category": "Education"
    },
    "win": {
      "target": "nsis"
    }
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@radix-ui/react-collapsible": "^1.1.13",
    "@radix-ui/react-select": "^2.3.0",
    "@react-router/express": "^7.17.0",
    "@react-router/serve": "^7.17.0",
    "@tailwindcss/vite": "^4.3.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.4.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "framer-motion": "^12.40.0",
    "fuse.js": "^7.4.2",
    "github-slugger": "^2.0.0",
    "gray-matter": "^4.0.3",
    "isbot": "^5.1.42",
    "katex": "^0.17.0",
    "lucide-react": "^1.18.0",
    "mdast-util-to-string": "^4.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-medium-image-zoom": "^5.4.7",
    "react-router": "^7.17.0",
    "reading-time": "^1.5.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-katex": "^7.0.1",
    "rehype-pretty-code": "^0.14.3",
    "rehype-react": "^8.0.0",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "shiki": "^4.2.0",
    "tailwind-merge": "^3.6.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.2.1",
    "@react-router/dev": "^7.17.0",
    "@react-router/node": "^7.17.0",
    "@storybook/addon-a11y": "^10.4.4",
    "@storybook/addon-docs": "^10.4.4",
    "@storybook/addon-mcp": "^0.6.0",
    "@storybook/addon-vitest": "^10.4.4",
    "@storybook/react-vite": "^10.4.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/express": "^5.0.6",
    "@types/katex": "^0.16.8",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/browser-playwright": "^4.1.8",
    "@vitest/coverage-v8": "^4.1.8",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3",
    "jsdom": "^29.1.1",
    "playwright": "^1.60.0",
    "storybook": "^10.4.4",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
